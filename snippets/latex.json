{
  "Section": {
    "prefix": "sec",
    "body": "\\section{${1:title}}"
  },
  "Subsection": {
    "prefix": "ssec",
    "body": "\\subsection{${1:title}}"
  },
  "Figure": {
    "prefix": "fig",
    "body": [
      "\\begin{figure}[${1:htbp}]",
      "\t\\centering",
      "\t\\includegraphics[width=${2:0.8}\\linewidth]{${3:filename}}",
      "\t\\caption{${4:caption}}",
      "\t\\label{fig:${5:label}}",
      "\\end{figure}"
    ]
  },
  "Itemize": {
    "prefix": "ite",
    "body": [
      "\\begin{itemize}",
      "\t\\item $0",
      "\\end{itemize}"
    ]
  },
  "Enumerate": {
    "prefix": "enum",
    "body": [
      "\\begin{enumerate}",
      "\t\\item $0",
      "\\end{enumerate}"
    ]
  },
  "Inline Math": {
    "prefix": "im",
    "body": "\\(${1}\\)$0"
  },
  "Display Math": {
    "prefix": "dm",
    "body": [
      "\\[",
      "\t${1}",
      "\\]",
      "$0"
    ]
  },
  "Equation": {
    "prefix": "eq",
    "body": [
      "\\begin{equation}",
      "\t${1}",
      "\\label{eq:${2}}",
      "\\end{equation}"
    ]
  },
  "Align": {
    "prefix": "ali",
    "body": [
      "\\begin{align}",
      "\t${1} &= ${2} \\\\",
      "\\end{align}"
    ]
  },
  "Fraction": {
    "prefix": "frac",
    "body": "\\frac{${1:num}}{${2:den}}"
  },
  "Sum": {
    "prefix": "sum",
    "body": "\\sum_{${1:i=0}}^{${2:n}} ${3}"
  },
  "Integral": {
    "prefix": "int",
    "body": "\\int_{${1:-\\infty}}^{${2:\\infty}} ${3} \\, d${4:x}"
  },
  "Limit": {
    "prefix": "lim",
    "body": "\\lim_{${1:n} \\to ${2:\\infty}} ${3}"
  },
  "Matrix": {
    "prefix": "bmat",
    "body": [
      "\\begin{bmatrix}",
      "\t${1} & ${2} \\\\",
      "\t${3} & ${4}",
      "\\end{bmatrix}"
    ]
  },
  "Vector norm": {
    "prefix": "norm",
    "body": "\\|${1}\\|"
  },
  "Hat": {
    "prefix": "hat",
    "body": "\\hat{${1}}"
  },
  "Bar": {
    "prefix": "bar",
    "body": "\\bar{${1}}"
  }
}
